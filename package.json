{
  "name": "usg-data-server",
  "version": "1.0.0",
  "description": "FOR PRIVATE ONLY",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "backup": "node scripts/manual-backup.js",
    "safe:stop": "bash scripts/safe-stop.sh",
    "safe:start": "bash scripts/safe-start.sh",
    "desktop": "electron .",
    "desktop:dev": "concurrently \"node src/server.js\" \"wait-on http://127.0.0.1:3000/login.html && electron .\"",
    "desktop:build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannyloyd19-bot/USG-DATA-SERVER.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mannyloyd19-bot/USG-DATA-SERVER/issues"
  },
  "homepage": "https://github.com/mannyloyd19-bot/USG-DATA-SERVER#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.usg.dataserver",
    "productName": "USG DATA SERVER",
    "files": [
      "public/**/*",
      "src/**/*",
      "electron-main.js",
      "package.json",
      "database.sqlite",
      "storage/**/*"
    ],
    "directories": {
      "buildResources": "public/assets"
    }
  }
}